unmanaged implementation in class zbp_r_kir_employee_um unique;
strict ( 2 );
with draft;
define behavior for ZR_KIR_EMPLOYEE_UM alias Employee
draft table ZDRKI_EMPLOYEE_u
//late numbering
early numbering
lock master
total etag Lastchangedat
authorization master ( global, instance )
etag master Locallastchangedat

{
  create ( authorization : global );
  update;
  delete;
  field ( readonly ) empId;
  draft action Activate optimized;
  draft action Discard;
  draft action Edit;
  draft action Resume;
  draft determine action Prepare;
  action(features : instance) SetActive parameter zkir_emp_status result[1] $self;
  factory action copy [1];
  static factory action upload[1];
  static action resetAll;
  internal action resetStatus;
  event studentEnrolled;
}

